# Copy this file to .env and replace the placeholder values.
# Never share the real .env file.

FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Generate a strong value:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret

# Use a dedicated MySQL user, not root.
DATABASE_URL=mysql+pymysql://helpdesk_app:replace-db-password@localhost:3306/helpdesk_db
# Ubuntu production example: /opt/helpdesk/app/static/uploads
# Windows production example: C:\HelpDesk\uploads
UPLOAD_FOLDER=/opt/helpdesk/app/static/uploads

# Email sending/fetching settings.
# For Gmail, use an App Password, not your normal Gmail password.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=helpdesk@example.com
MAIL_PASSWORD=replace-mail-app-password
MAIL_DEFAULT_SENDER=helpdesk@example.com

# Email auto fetch interval, default 10 minutes.
EMAIL_AUTO_FETCH_ENABLED=True
EMAIL_AUTO_FETCH_INTERVAL_SECONDS=600
